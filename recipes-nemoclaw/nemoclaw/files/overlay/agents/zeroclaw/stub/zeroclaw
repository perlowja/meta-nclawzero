# │  This file is NOT present in the real zeroclaw-sandbox-base     │
# │  image. Remove agents/zeroclaw/stub/ from the repo when the     │
# │  live testing path is confirmed working on Brev.                │
# │  Live image pulls the real zeroclaw binary from GitHub Releases:│
# │    https://github.com/zeroclaw-labs/zeroclaw/releases           │
# └─────────────────────────────────────────────────────────────────┘

import json
import os
import sys

STUB_VERSION = "0.6.9-stub"
GATEWAY_PORT = int(os.environ.get("GATEWAY_PORT", "42617"))


def serve_health(port: int) -> None:
    from http.server import BaseHTTPRequestHandler, HTTPServer

    class HealthHandler(BaseHTTPRequestHandler):
        def do_GET(self) -> None:  # noqa: N802
            if self.path in ("/health", "/health/"):
                body = json.dumps(
                    {"status": "ok", "version": STUB_VERSION, "stub": True}
                ).encode()
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
            else:
                self.send_response(404)
                self.end_headers()

        def log_message(self, fmt: str, *args: object) -> None:  # noqa: ANN001
            pass  # suppress access log

    print(
        f"[stub] zeroclaw {STUB_VERSION} gateway listening on 0.0.0.0:{port}",
        flush=True,
    )
    HTTPServer(("0.0.0.0", port), HealthHandler).serve_forever()


def main() -> None:
    args = sys.argv[1:]

    if not args or args[0] in ("--version", "-V", "version"):
        print(f"zeroclaw {STUB_VERSION}")
        return

    if args[:2] == ["gateway", "start"]:
        serve_health(GATEWAY_PORT)
        return

    if args[:2] == ["gateway", "get-paircode"]:
        print("stub-paircode-00000000")
        return

    if args[:1] == ["status"]:
        # Any status subcommand → healthy (exit 0)
        sys.exit(0)

    print(f"zeroclaw stub: unknown command: {' '.join(args)}", file=sys.stderr)
    sys.exit(1)


if __name__ == "__main__":
    main()
