# SPDX-License-Identifier: Apache-2.0
# /etc/zeroclaw/env — runtime environment for ZeroClaw daemon.
#
# Loaded by zeroclaw.service via EnvironmentFile=-/etc/zeroclaw/env.
# This file ships empty on first boot. Populate on the device; DO NOT
# commit populated values to images.
#
# Mode 0600, owned zeroclaw:zeroclaw. The daemon reads it as the
# zeroclaw user.

# --- Primary inference provider: Together AI (hyperscale, multi-model) ---
# Same key serves both tiers.
TOGETHER_API_KEY=

# --- Alternate consultative endpoints (optional, runtime-swappable) ---
GOOGLE_VERTEX_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=

# --- InvestorClaw HMAC consultation fingerprint chain ---
INVESTORCLAW_CONSULTATION_ENABLED=true
INVESTORCLAW_CONSULTATION_HMAC_KEY=

# --- Optional fallback providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=
XAI_API_KEY=

# --- ZeroClaw web UI bearer auth (optional) ---
ZEROCLAW_API_KEY=
