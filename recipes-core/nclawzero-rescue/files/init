#!/bin/sh
# SPDX-License-Identifier: Apache-2.0
#
# /init for nclawzero Jetson PXE rescue initramfs.
#
# Replaces busybox's default stub. Runs as PID 1 inside the cpio.gz
# initramfs unpacked by the kernel after PXE handoff.
#
# Boot sequence (post kernel handoff):
#   1. Mount /proc, /sys, /dev, /tmp.
#   2. Load every plausible Jetson NIC driver (RTL8168/R8169 for the
#      Orin Nano dev kit P3768 carrier, nvethernet for production
#      carriers with the Tegra234 EQOS like P3767-1000) — keep it
#      NIC-agnostic so the rescue works on whichever Jetson lands.
#   3. Iterate every non-loopback interface that came up; udhcpc until
#      one gets a lease. First one to win drives the rescue session.
#   4. Generate ephemeral dropbear host key on tmpfs.
#   5. Start dropbear in BACKGROUND on :22, then exec /bin/sh so PID 1
#      is the operator console. If the operator never SSHs and dropbear
#      crashes, the console shell still survives.
#
# Idempotency: every step is gated on "is it already done?" so a re-run
# (e.g. after a fork() or a panic-and-restart-of-init) doesn't double-mount.

set -eu

log() { echo "[ncz-rescue] $*" > /dev/kmsg 2>/dev/null || echo "[ncz-rescue] $*"; }

# --- 1. pseudo-filesystems -------------------------------------------------

mountpoint -q /proc 2>/dev/null || mount -t proc     proc     /proc
mountpoint -q /sys  2>/dev/null || mount -t sysfs    sys      /sys
mountpoint -q /dev  2>/dev/null || mount -t devtmpfs devtmpfs /dev || mount -t tmpfs tmpfs /dev
mountpoint -q /tmp  2>/dev/null || mount -t tmpfs    tmpfs    /tmp
mountpoint -q /run  2>/dev/null || mount -t tmpfs    tmpfs    /run

log "pseudo-fs mounted"

# Refresh module dependency map.  The cpio ships a pre-generated
# modules.dep but a stale dep file silently breaks modprobe; depmod -a
# rebuilds against the modules actually present.  Cheap insurance.
depmod -a 2>/dev/null || true

# --- 2. PCIe + NIC drivers (NIC-agnostic) ---------------------------------
#
# Order matters on Tegra: the dev kit's onboard NIC (RTL8168) is PCIe-
# attached, NOT direct-bus.  Without the Tegra PCIe controller + serdes
# PHY loaded FIRST, the bus never enumerates → r8169 has nothing to bind
# to → no eth interface → no DHCP → no rescue.  This was the failure
# mode observed 2026-04-26: kernel handed off cleanly, screen went black,
# device fully unreachable on the LAN because the NIC never came up.
#
# Two distinct edge-NIC paths depending on which Jetson carrier we landed:
#
#   Orin Nano dev kit P3768 carrier:   PCIe RTL8168 → r8169 + realtek_phy
#                                      + linux-firmware-rtl-nic
#                                      (requires Tegra PCIe stack)
#   Production carriers w/ EQOS:       Tegra234 onboard → nvethernet
#                                      (NVIDIA OOT, depends on stmmac /
#                                      phylink / mdio_devres)
#
# Load PCIe stack first, then both NIC chains in order.  modprobe -q is
# a no-op if a module isn't present (i.e. the chain we're not on);
# missing deps must NOT abort rescue boot.  ip-link probe in step 3
# decides which interface actually came up.

for m in \
    phy-tegra194-p2u pcie-tegra194 \
    nvme-core nvme \
    mdio_devres mdio_bus phylink \
    realtek_phy r8169 \
    stmmac stmmac_platform nvethernet \
; do
    modprobe -q "$m" 2>/dev/null || true
done

# Give PCIe enumeration + NIC probe a beat before walking interfaces.
# Without this, the ip-link loop below can fire before the RTL chip is
# bound, mistakenly reporting "no NIC" on a slow-enumeration carrier.
sleep 2

# Wait briefly for udev to settle interface device nodes.  devtmpfs +
# kernel uevents normally produce eth* within ~500ms; give it 5s to be
# generous on slower carriers.
i=0
while [ $i -lt 20 ]; do
    if ip -o link show 2>/dev/null | awk -F: '$2 !~ /lo/ && $2 ~ /eth|enp|enx/ {found=1} END {exit !found}'; then
        break
    fi
    sleep 0.25
    i=$((i + 1))
done

# --- 3. DHCP on whichever interface actually appeared ---------------------

ACTIVE_IFACE=""
ACTIVE_IP=""

for IFACE in $(ip -o link show 2>/dev/null | awk -F': ' '$2 !~ /^lo/ && $2 ~ /^(eth|enp|enx)/ {print $2}'); do
    log "trying ${IFACE}"
    ip link set "${IFACE}" up || continue

    # Short DHCP timeout per interface — if this one is unplugged, we
    # want to move on to the next one quickly.
    if udhcpc -i "${IFACE}" -t 4 -T 2 -A 3 -n -q \
              -s /usr/share/udhcpc/default.script > /dev/null 2>&1; then
        ip4=$(ip -4 addr show "${IFACE}" | awk '/inet / {print $2}' | head -1)
        if [ -n "${ip4}" ]; then
            ACTIVE_IFACE="${IFACE}"
            ACTIVE_IP="${ip4}"
            log "DHCP success on ${IFACE}: ${ip4}"
            break
        fi
    fi
done

if [ -z "${ACTIVE_IFACE}" ]; then
    log "WARN: no NIC got a DHCP lease — operator must assign IP via console"
fi

# --- 4. SSH host keys -------------------------------------------------------
#
# Generate dropbear's host key on first boot. The keys are ephemeral
# (live only in tmpfs for the duration of this PXE session); operator
# verifies fingerprints out-of-band — there's no persistent identity
# for a rescue initramfs that PXE-boots fresh every time.

if [ ! -f /etc/dropbear/dropbear_ed25519_host_key ]; then
    install -d -m 0700 /etc/dropbear
    dropbearkey -t ed25519 -f /etc/dropbear/dropbear_ed25519_host_key 2>&1 | \
        grep "^Fingerprint" | sed 's/^/[ncz-rescue] dropbear /' || true
fi

# --- 5. dropbear (background) + console shell (PID 1) ---------------------
#
# Background dropbear with -F kept under setsid so it survives even if
# our shell exits. PID 1 stays as this script, which then exec's /bin/sh
# for HDMI/UART operator control. If dropbear crashes, the console
# survives — and vice versa, so neither failure mode produces an
# unrecoverable state.
#
# -F  foreground (we wrap in setsid + & so it doesn't fork itself)
# -E  log to stderr (which goes to kmsg via the redirect below)
# -p  port (default 22)
# -r  ed25519 host key path

log "starting dropbear on :22 — operator can ssh root@${ACTIVE_IP:-<no-ip>}"

setsid sh -c '
    while true; do
        dropbear -F -E -p 22 -r /etc/dropbear/dropbear_ed25519_host_key \
            > /dev/kmsg 2>&1 || true
        echo "[ncz-rescue] dropbear exited rc=$? — respawning in 5s" > /dev/kmsg 2>&1
        sleep 5
    done
' </dev/null >/dev/kmsg 2>&1 &

DROPBEAR_PID=$!
log "dropbear supervisor pid=${DROPBEAR_PID}"

# PID 1 lives on as the console shell — never exits, always provides a
# UART / HDMI rescue path even if everything else falls over.
log "console shell ready on PID 1 — HDMI/UART operator has a real shell"
exec /bin/sh
