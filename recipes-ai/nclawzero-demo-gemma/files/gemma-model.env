# Environment overrides for the Gemma demo model.
# The fetch service + llama-server both EnvironmentFile this; edit and
# `systemctl restart nclawzero-demo-gemma-fetch` to switch model.
#
# Defaults are in fetch-gemma.sh; uncomment to override.
#
# MODEL_URL=https://huggingface.co/unsloth/gemma-2-2b-it-GGUF/resolve/main/gemma-2-2b-it-Q4_K_M.gguf
# MODEL_PATH=/var/lib/models/gemma.gguf
